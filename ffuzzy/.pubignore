# Dev-only artifacts excluded from the published package (keeps it lean).
# The plugin ships C SOURCE (src/, ffi/, include/) + platform build glue; the
# native library is built per-platform on the consumer's machine.
# NOTE: gitignore syntax — comments must be on their own line (no inline #).
build/
tests/
tool/
tools/
*.o
*.obj
*.so
*.so.debug
*.dll
*.dylib
*.exe
*.pdb
*.a
*.lib

# Dev-only: internal planning docs, build/codegen scripts, and the separate
# npm (@codejoo/ffuzzy) WASM distribution — none belong in the Dart package.
docs/
scripts/
wasm/
.claude/

# Benchmark-only: a 7 MB corpus fixture and the bench test that loads it.
# Real unit tests (test/corpus_mutation_test.dart) still ship.
mock.json
test/bench_native_test.dart
