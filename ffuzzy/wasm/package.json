{
  "name": "@codejoo/ffuzzy",
  "version": "0.7.0",
  "description": "Fast fuzzy search for the web — WASM port of the ffuzzy C engine. Five search modes, Unicode, TypeScript, browser + Node.",
  "type": "module",
  "exports": {
    ".": {
      "import": "./ffuzzy.js",
      "types": "./ffuzzy.d.ts"
    },
    "./lite": {
      "import": "./ffuzzy-lite.js",
      "types": "./ffuzzy-lite.d.ts"
    }
  },
  "files": [
    "ffuzzy.js",
    "ffuzzy.d.ts",
    "ffuzzy-lite.js",
    "ffuzzy-lite.d.ts",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node build.mjs",
    "build:engine": "bash build-engine.sh",
    "test": "node build.mjs && node --test",
    "prepublishOnly": "node build.mjs"
  },
  "keywords": [
    "fuzzy-search",
    "fuzzy",
    "search",
    "matcher",
    "wasm",
    "webassembly",
    "typescript",
    "fzf",
    "nucleo",
    "unicode",
    "cjk",
    "subsequence",
    "fuzzy-matching",
    "autocomplete",
    "filter",
    "highlight",
    "browser",
    "node"
  ],
  "homepage": "https://github.com/icodejoo/ffuzzy",
  "repository": {
    "type": "git",
    "url": "https://github.com/icodejoo/ffuzzy.git",
    "directory": "wasm"
  },
  "bugs": {
    "url": "https://github.com/icodejoo/ffuzzy/issues"
  },
  "license": "MIT",
  "author": "jelon <jelon@tbu.net>",
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "fuse.js": "^7.4.2",
    "fuzzysort": "^3.1.0"
  }
}
